<!DOCTYPE html>
<html lang="en"> 
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Interactive Osmosis Lab</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: #f1f5f9;
      color: #1e293b;
    }
    .app {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    header {
      background: #075985;
      color: white;
      padding: 18px;
      text-align: center;
      box-shadow: 0 2px 6px rgba(0,0,0,.18);
    }
    header h1 {
      margin: 0 0 6px 0;
      font-size: 28px;
    }
    header p {
      margin: 0;
      color: #bae6fd;
      font-size: 14px;
    }
    main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .panel {
      width: 100%;
      max-width: 1100px;
      background: white;
      border-radius: 22px;
      overflow: hidden;
      box-shadow: 0 12px 35px rgba(0,0,0,.12);
      border: 1px solid #e2e8f0;
    }
    .top {
      padding: 30px;
      background: #f8fafc;
      border-bottom: 1px solid #e2e8f0;
      text-align: center;
    }
    .top h2, .bottom h2 {
      margin-top: 0;
      margin-bottom: 24px;
      color: #334155;
    }
    .cell-grid {
      display: flex;
      justify-content: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .cell-card {
      width: 190px;
      min-height: 190px;
      border: 2px solid #cbd5e1;
      border-radius: 18px;
      background: white;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      cursor: pointer;
      transition: .2s ease;
      box-shadow: 0 2px 10px rgba(0,0,0,.05);
      padding: 14px;
      user-select: none;
    }
    .cell-card:hover { transform: translateY(-3px); border-color: #7dd3fc; }
    .cell-card.active {
      border-color: #0ea5e9;
      box-shadow: 0 0 0 5px rgba(14,165,233,.12);
      transform: scale(1.03);
    }
    .animal-icon {
      width: 72px;
      height: 72px;
      border-radius: 50%;
      background: #f87171;
      border: 5px solid #b91c1c;
      margin-bottom: 14px;
    }
    .plant-icon {
      width: 72px;
      height: 72px;
      background: #bbf7d0;
      border: 5px solid #166534;
      position: relative;
      margin-bottom: 14px;
    }
    .plant-icon::after {
      content: "";
      position: absolute;
      top: 8px;
      left: 8px;
      width: 36px;
      height: 42px;
      background: #bfdbfe;
    }
    .cell-title { font-weight: 700; text-align: center; }
    .cell-sub { font-size: 12px; color: #64748b; text-align: center; margin-top: 4px; }
    .bottom {
      padding: 30px;
      background: #f5f5f4;
      text-align: center;
      position: relative;
    }
    .beaker-grid {
      display: flex;
      justify-content: center;
      align-items: flex-end;
      gap: 28px;
      flex-wrap: wrap;
      padding-bottom: 24px;
    }
    .beaker-wrap {
      width: 220px;
      cursor: pointer;
      transition: .2s ease;
    }
    .beaker-wrap:hover { transform: translateY(-6px); }
    .beaker {
      width: 170px;
      height: 210px;
      margin: 0 auto;
      border: 4px solid white;
      border-top: 0;
      border-radius: 0 0 22px 22px;
      background: rgba(255,255,255,.35);
      position: relative;
      overflow: hidden;
      box-shadow: inset 0 -10px 20px rgba(0,0,0,.08);
      backdrop-filter: blur(2px);
    }
    .water {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      height: 58%;
      background: rgba(125, 211, 252, .6);
    }
    .label {
      position: absolute;
      left: 50%;
      bottom: 18px;
      transform: translateX(-50%);
      background: rgba(255,255,255,.92);
      padding: 6px 12px;
      border-radius: 10px;
      font-weight: 700;
      font-size: 14px;
      white-space: nowrap;
    }
    .beaker-desc {
      margin-top: 10px;
      font-size: 13px;
      color: #475569;
      line-height: 1.35;
    }
    .table-edge {
      position: absolute;
      left: 0; right: 0; bottom: 0;
      height: 24px;
      background: #d6d3d1;
      border-top: 4px solid #a8a29e;
    }
    .hint {
      font-size: 14px;
      color: #0369a1;
      margin-bottom: 14px;
    }

    .result {
      display: flex;
      flex-wrap: wrap;
      min-height: 540px;
    }
    .left {
      flex: 1 1 58%;
      min-width: 320px;
      background: #0f172a;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .scope-label {
      position: absolute;
      top: 16px;
      left: 16px;
      color: #94a3b8;
      font-family: monospace;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .12em;
    }
    .viewport {
      width: 360px;
      height: 360px;
      border-radius: 50%;
      border: 8px solid #334155;
      background: #1e293b;
      position: relative;
      overflow: hidden;
      box-shadow: inset 0 0 50px rgba(0,0,0,.75);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .viewport-bg {
      position: absolute;
      inset: 0;
      transition: background .7s ease;
    }
    .bg-hypotonic { background: rgba(224,242,254,.16); }
    .bg-isotonic { background: rgba(148,163,184,.12); }
    .bg-hypertonic { background: rgba(49,46,129,.24); }
    .glare {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top right, transparent, rgba(255,255,255,.06), transparent);
      pointer-events: none;
    }

    .sim-box {
      width: 250px;
      height: 250px;
      position: relative;
      z-index: 2;
    }

    .animal-cell {
      width: 92px;
      height: 92px;
      border-radius: 50%;
      margin: 79px auto;
      background: radial-gradient(circle at 30% 30%, #fca5a5, #ef4444 72%, #b91c1c 100%);
      border: 2px solid #991b1b;
      transition: all 1.8s ease-in-out;
      position: relative;
      box-shadow: 0 6px 15px rgba(0,0,0,.25);
    }
    .animal-cell.hypotonic {
      transform: scale(1.42);
      opacity: .32;
    }
    .animal-cell.hypertonic {
      transform: scale(.72);
      border-radius: 38% 57% 42% 61% / 53% 42% 59% 40%;
      clip-path: polygon(50% 0%, 61% 11%, 75% 6%, 80% 20%, 94% 24%, 88% 38%, 100% 50%, 88% 62%, 94% 76%, 80% 80%, 75% 94%, 61% 89%, 50% 100%, 39% 89%, 25% 94%, 20% 80%, 6% 76%, 12% 62%, 0% 50%, 12% 38%, 6% 24%, 20% 20%, 25% 6%, 39% 11%);
    }

    .burst-dot {
      width: 10px;
      height: 10px;
      background: #ef4444;
      border-radius: 50%;
      position: absolute;
      opacity: 0;
      animation: burst 1s forwards;
    }
    @keyframes burst {
      0% { opacity: 0; transform: scale(.8); }
      50% { opacity: 1; }
      100% { opacity: 0; transform: scale(1.4); }
    }

    .plant-wall {
      position: absolute;
      left: 45px;
      top: 20px;
      width: 160px;
      height: 210px;
      background: #f0fdf4;
      border: 10px solid #166534;
      border-radius: 6px;
    }
    .plant-membrane, .vacuole, .chloroplast {
      position: absolute;
      transition: all 1.8s ease-in-out;
    }
    .plant-membrane {
      background: #86efac;
      border: 2px solid #22c55e;
    }
    .vacuole {
      background: rgba(186,230,253,.8);
      border: 2px solid #7dd3fc;
    }
    .chloroplast {
      width: 12px; height: 12px; border-radius: 50%;
      background: #15803d;
    }

    .arrow {
      position: absolute;
      width: 34px;
      height: 6px;
      background: #3b82f6;
      border-radius: 4px;
      animation: pulse 1.2s infinite;
    }
    .arrow::after {
      content: "";
      position: absolute;
      right: -2px;
      top: -5px;
      border-left: 10px solid #3b82f6;
      border-top: 8px solid transparent;
      border-bottom: 8px solid transparent;
    }
    .arrow.out::after {
      right: auto;
      left: -2px;
      border-left: 0;
      border-right: 10px solid #3b82f6;
    }
    @keyframes pulse {
      0%,100% { opacity: .55; }
      50% { opacity: 1; }
    }

    .right {
      flex: 1 1 42%;
      min-width: 280px;
      background: #f0f9ff;
      padding: 32px;
      display: flex;
      flex-direction: column;
    }
    .obs-label {
      font-size: 13px;
      font-weight: 700;
      color: #0284c7;
      text-transform: uppercase;
      letter-spacing: .08em;
      margin-bottom: 8px;
    }
    .result h2 {
      margin: 0 0 18px 0;
      font-size: 34px;
      color: #1e293b;
    }
    .explanation {
      background: white;
      border-radius: 16px;
      padding: 18px;
      border: 1px solid #e0f2fe;
      box-shadow: 0 2px 10px rgba(0,0,0,.05);
      line-height: 1.6;
      color: #334155;
      font-size: 18px;
    }
    .reset-btn {
      margin-top: auto;
      padding: 14px 20px;
      border: 0;
      border-radius: 14px;
      background: #0284c7;
      color: white;
      font-weight: 700;
      font-size: 16px;
      cursor: pointer;
      box-shadow: 0 4px 14px rgba(2,132,199,.2);
    }
    .reset-btn:hover { background: #0369a1; }

    @media (max-width: 800px) {
      .viewport { width: 300px; height: 300px; }
      .result h2 { font-size: 28px; }
      .sim-box { width: 220px; height: 220px; }
      .plant-wall { left: 30px; width: 150px; height: 190px; }
    }
  </style>
</head>
<body>
  <div class="app">
    <header>
      <h1>Interactive Osmosis Lab</h1>
      <p>Investigate how different cells react to different environments.</p>
    </header>

    <main>
      <div id="app-root" class="panel"></div>
    </main>
  </div>

  <script>
    const CELL_TYPES = [
      { id: 'animal', name: 'Animal Cell', subtitle: '(Red Blood Cell)' },
      { id: 'plant', name: 'Plant Cell', subtitle: '(Elodea Leaf)' }
    ];

    const SOLUTIONS = [
      { id: 'hypotonic', name: 'Hypotonic', desc: 'Lower solute concentration outside. Water enters the cell.' },
      { id: 'isotonic', name: 'Isotonic', desc: 'Equal solute concentration. Water movement is balanced.' },
      { id: 'hypertonic', name: 'Hypertonic', desc: 'Higher solute concentration outside. Water leaves the cell.' }
    ];

    const SIMULATION_DATA = {
      animal: {
        hypotonic: {
          title: 'Cytolysis (Lysis)',
          explanation: 'Water rapidly enters the animal cell by osmosis due to the lower solute concentration outside. Without a rigid cell wall, the cell swells and eventually bursts.'
        },
        isotonic: {
          title: 'Normal State',
          explanation: 'Water moves into and out of the cell at equal rates. The cell maintains its normal biconcave disc shape and functions optimally.'
        },
        hypertonic: {
          title: 'Crenation',
          explanation: 'Water leaves the cell by osmosis, moving toward the higher solute concentration outside. The cell shrinks, shrivels, and becomes spiked (crenated).'
        }
      },
      plant: {
        hypotonic: {
          title: 'Turgid (Normal)',
          explanation: 'Water enters the cell. The central vacuole swells, pushing the plasma membrane tightly against the rigid cell wall. This turgor pressure keeps the plant upright.'
        },
        isotonic: {
          title: 'Flaccid',
          explanation: 'Water moves in and out equally. The plant cell is not fully pressurized against its cell wall, causing the plant tissue to become limp or flaccid.'
        },
        hypertonic: {
          title: 'Plasmolysis',
          explanation: 'Water leaves the cell. The central vacuole shrinks, and the plasma membrane pulls away from the cell wall. This causes the plant to wilt.'
        }
      }
    };

    let activeCell = null;
    let simulation = null;

    const root = document.getElementById('app-root');

    function render() {
      if (!simulation) {
        root.innerHTML = `
          <div class="top">
            <h2>1. Select a Cell Type</h2>
            <div class="hint">Click a cell, then click a solution.</div>
            <div class="cell-grid">
              ${CELL_TYPES.map(cell => `
                <div class="cell-card ${activeCell === cell.id ? 'active' : ''}" onclick="selectCell('${cell.id}')">
                  ${cell.id === 'animal' ? '<div class="animal-icon"></div>' : '<div class="plant-icon"></div>'}
                  <div class="cell-title">${cell.name}</div>
                  <div class="cell-sub">${cell.subtitle}</div>
                </div>
              `).join('')}
            </div>
          </div>
          <div class="bottom">
            <h2>2. Drop into a Solution</h2>
            <div class="beaker-grid">
              ${SOLUTIONS.map(sol => `
                <div class="beaker-wrap" onclick="startSimulation('${sol.id}')">
                  <div class="beaker">
                    <div class="water"></div>
                    <div class="label">${sol.name}</div>
                  </div>
                  <div class="beaker-desc">${sol.desc}</div>
                </div>
              `).join('')}
            </div>
            <div class="table-edge"></div>
          </div>
        `;
        return;
      }

      const result = SIMULATION_DATA[simulation.cell][simulation.solution];

      root.innerHTML = `
        <div class="result">
          <div class="left">
            <div class="scope-label">Microscope View: ${simulation.solution} environment</div>
            <div class="viewport">
              <div class="viewport-bg bg-${simulation.solution}"></div>
              <div class="sim-box">
                ${simulation.cell === 'animal' ? renderAnimal(simulation.solution) : renderPlant(simulation.solution)}
                ${renderArrows(simulation.solution)}
              </div>
              <div class="glare"></div>
            </div>
          </div>
          <div class="right">
            <div class="obs-label">Observation Result</div>
            <h2>${result.title}</h2>
            <div class="explanation">${result.explanation}</div>
            <button class="reset-btn" onclick="resetSimulation()">Reset Experiment</button>
          </div>
        </div>
      `;
    }

    function renderAnimal(solution) {
      const burst = solution === 'hypotonic'
        ? `
          <div class="burst-dot" style="left:120px; top:10px;"></div>
          <div class="burst-dot" style="left:175px; top:45px; animation-delay:.08s;"></div>
          <div class="burst-dot" style="left:200px; top:110px; animation-delay:.16s;"></div>
          <div class="burst-dot" style="left:175px; top:175px; animation-delay:.24s;"></div>
          <div class="burst-dot" style="left:120px; top:210px; animation-delay:.32s;"></div>
          <div class="burst-dot" style="left:50px; top:175px; animation-delay:.4s;"></div>
          <div class="burst-dot" style="left:20px; top:110px; animation-delay:.48s;"></div>
          <div class="burst-dot" style="left:50px; top:45px; animation-delay:.56s;"></div>
        `
        : '';

      return `<div class="animal-cell ${solution}"></div>${burst}`;
    }

    function renderPlant(solution) {
      let membrane = { left: 55, top: 30, width: 130, height: 170, radius: 6 };
      let vacuole = { left: 82, top: 57, width: 76, height: 116, radius: 10 };

      if (solution === 'hypotonic') {
        membrane = { left: 45, top: 20, width: 150, height: 190, radius: 0 };
        vacuole = { left: 50, top: 25, width: 140, height: 180, radius: 4 };
      } else if (solution === 'hypertonic') {
        membrane = { left: 72, top: 48, width: 96, height: 136, radius: 20 };
        vacuole = { left: 100, top: 80, width: 40, height: 70, radius: 16 };
      }

      return `
        <div class="plant-wall"></div>
        <div class="plant-membrane" style="left:${membrane.left}px; top:${membrane.top}px; width:${membrane.width}px; height:${membrane.height}px; border-radius:${membrane.radius}px;"></div>
        <div class="chloroplast" style="left:${membrane.left + 16}px; top:${membrane.top + 18}px;"></div>
        <div class="chloroplast" style="left:${membrane.left + membrane.width - 28}px; top:${membrane.top + 28}px;"></div>
        <div class="chloroplast" style="left:${membrane.left + 22}px; top:${membrane.top + membrane.height - 30}px;"></div>
        <div class="chloroplast" style="left:${membrane.left + membrane.width - 32}px; top:${membrane.top + membrane.height - 24}px;"></div>
        <div class="vacuole" style="left:${vacuole.left}px; top:${vacuole.top}px; width:${vacuole.width}px; height:${vacuole.height}px; border-radius:${vacuole.radius}px;"></div>
      `;
    }

    function renderArrows(solution) {
      let html = '';
      if (solution === 'hypotonic' || solution === 'isotonic') {
        html += `<div class="arrow" style="left:10px; top:115px;"></div>`;
        html += `<div class="arrow" style="right:10px; top:60px; transform: rotate(145deg);"></div>`;
      }
      if (solution === 'hypertonic' || solution === 'isotonic') {
        html += `<div class="arrow out" style="right:18px; top:115px;"></div>`;
        html += `<div class="arrow out" style="left:26px; bottom:42px; transform: rotate(-45deg);"></div>`;
      }
      return html;
    }

    function selectCell(cellId) {
      activeCell = cellId;
      render();
    }

    function startSimulation(solutionId) {
      if (!activeCell) {
        alert('Select a cell first.');
        return;
      }
      simulation = { cell: activeCell, solution: solutionId };
      activeCell = null;
      render();
    }

    function resetSimulation() {
      simulation = null;
      activeCell = null;
      render();
    }

    window.selectCell = selectCell;
    window.startSimulation = startSimulation;
    window.resetSimulation = resetSimulation;

    render();
  </script>
</body>
</html>
